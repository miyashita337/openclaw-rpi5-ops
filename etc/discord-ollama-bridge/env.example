# Discord ↔ Ollama bridge bot 環境変数
#
# 設置先: /etc/discord-ollama-bridge/env (root:discord-bridge 0640)
# 注意: DISCORD_TOKEN は新規作成した bot 専用トークン。openclaw-gateway と同じ
# bot を共有すると WebSocket セッションが奪い合いになり両方が落ちる。

DISCORD_TOKEN=__REPLACE_WITH_NEW_BOT_TOKEN__
OLLAMA_URL=http://100.123.241.106:11434
OLLAMA_MODEL=qwen3.6:27b
OLLAMA_TIMEOUT=300
LOG_LEVEL=INFO
