# Cowork bootstrap secrets - copy to .env (gitignored) and fill in values
# Used by scripts/cowork-bootstrap.sh

# GitHub Personal Access Token (classic or fine-grained)
# Required scopes: repo, read:org (workflow if you'll edit Actions)
GH_TOKEN=

# Optional: default repo for gh commands (owner/repo)
GH_REPO=miyashita337/openclaw-rpi5-ops
